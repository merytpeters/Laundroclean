// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// ENUMS

enum UserType {
  COMPANYUSER
  CLIENT
}

enum TokenType {
  ACCESS
  REFRESH
  RESET
}

enum NotificationType {
  EMAIL
  SMS
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
}

enum Currency {
  DOLLAR
  NAIRA
  POUNDS
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS  @map("IN PROGRESS")
  COMPLETED
  CANCELLED
}

enum DeliveryType {
  DROP_OFF  @map("DROP OFF")
  PICK_UP   @map("PICK UP")
}

enum PricingType {
  PER_KG        @map("PER KG")
  PER_ITEM      @map("PER ITEM")
  FLAT_RATE     @map("FLAT RATE")
}


// MODELS


model CompanyRoleTitle {
  id              Int      @id @default(autoincrement())
  title           String   @unique
  level           Int?
  permissions     String[] @default([])
  users           User[]

  @@map("companyRoleTitle")
}

model User {
  id            String              @id @default(uuid())
  firstName     String?             @map("first_name")
  lastName      String?             @map("last_name")
  email         String              @unique
  password      String
  type          UserType
  roleId        Int?
  role          CompanyRoleTitle?   @relation(fields: [roleId], references: [id])
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  deletedAt     DateTime?           @map("deleted_at")
  isActive      Boolean             @default(true)

  tokens        Token[]
  profile       Profile?
  notifications Notification[]

  @@map("users")
}

model Token {
  id         String     @id @default(uuid())
  token      String     @unique
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       TokenType
  expiresAt  DateTime   @map("expires_at")
  valid      Boolean    @default(true)
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  @@map("tokens")
}

model Profile {
  id                  String     @id @default(uuid())
  userId              String     @unique @map("user_id")
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  isTemp              Boolean    @default(false)
  avatarUrl           String?    @map("avatar_url")
  avatarPublicId      String?    @map("avatar_public_id")
  phoneNumber         String?    @map("phone_number")
  addressLine1        String?    @map("address_line_1")
  addressLine2        String?    @map("address_line_2")
  city                String?
  state               String?
  postalCode          String?    @map("postal_code")
  paymentMethodToken  String?    @map("payment_method_token")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  deletedAt           DateTime?  @map("deleted_at")

  bookings            Booking[]  @relation("BookingProfile")
  addressBookings     Booking[]  @relation("BookingAddress")

  @@map("profiles")
}

model Notification {
  id                   String                  @id @default(uuid())
  userId               String?                 @map("user_id")
  user                 User?                   @relation(fields: [userId], references: [id])
  types                NotificationType[]
  title                String?
  message              String
  status               NotificationStatus
  sentAt               DateTime?               @map("sent_at")
  priority             NotificationPriority

  bookingNotifications BookingNotifications[]

  @@map("notifications")
}

model Service {
  id            String           @id @default(uuid())
  name          String
  description   String
  isActive      Boolean          @default(true) @map("is_active")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  deletedAt     DateTime?        @map("deleted_at")

  bookings      Booking[]
  prices        ServicePrice[]

  @@map("services")
}

model ServicePrice {
  id            String        @id @default(uuid())
  serviceId     String        @map("service_id")
  service       Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  amount        Decimal
  currency      Currency
  pricingType   PricingType   @map("pricing_type")

  isActive      Boolean       @default(true) @map("is_active")

  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@index([serviceId, isActive])
  @@map("service_prices")
}


model Booking {
  id                String           @id @default(uuid())
  profileId         String           @map("profile_id")
  profile           Profile          @relation("BookingProfile", fields: [profileId], references: [id])
  customBookingId   String          @unique @map("custom_booking_id")

  serviceId         String           @map("service_id")
  service           Service          @relation(fields: [serviceId], references: [id])

  unitPrice         Decimal          @map("unit_price")
  currency          Currency
  pricingType       PricingType      @map("pricing_type")
  totalAmount       Decimal          @map("total_amount")

  status            BookingStatus

  deliveryType      DeliveryType     @map("delivery_type")
  scheduledDate     DateTime?        @map("scheduled_date")
  pickupTime        DateTime?        @map("pickup_time")

  weight            Float?
  itemCount         Int?             @map("item_count")

  addressId         String?          @map("address_id")
  address           Profile?         @relation("BookingAddress", fields: [addressId], references: [id])
  additionalNote    String?          @map("additional_note")

  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  deletedAt         DateTime?        @map("deleted_at")
  isActive          Boolean          @default(true)

  bookingNotifications BookingNotifications[]

  @@map("bookings")
}

model BookingNotifications {
  bookingId      String @map("booking_id")
  booking        Booking @relation(fields: [bookingId], references: [id])
  notificationId String @map("notification_id")
  notification   Notification @relation(fields: [notificationId], references: [id])

  @@map("booking_notifications")
  @@id([bookingId, notificationId])
}
